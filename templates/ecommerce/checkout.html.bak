{% extends "ecommerce_base.html" %}
{% load static %}

{% block title %}Checkout - Whole Earn{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 py-12 sm:py-16">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-[#ec3183] mb-2">Checkout</h1>
    <p class="text-[#ec3183] opacity-80">Complete your purchase</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Checkout Form -->
    <div class="lg:col-span-2">
      <!-- Shipping Information -->
      <div class="bg-white rounded-lg border border-pink-100 p-6 mb-6">
        <h2 class="text-2xl font-bold text-[#ec3183] mb-6">Shipping Address</h2>
        <form method="post" class="space-y-4">
          {% csrf_token %}

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="first_name" class="block text-sm font-medium text-[#ec3183] mb-2">First Name *</label>
              <input type="text" id="first_name" name="first_name" value="{{ user.first_name }}" required class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
            </div>
            <div>
              <label for="last_name" class="block text-sm font-medium text-[#ec3183] mb-2">Last Name *</label>
              <input type="text" id="last_name" name="last_name" value="{{ user.last_name }}" required class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-[#ec3183] mb-2">Email *</label>
            <input type="email" id="email" name="email" value="{{ user.email }}" required class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-[#ec3183] mb-2">Phone Number *</label>
            <input type="tel" id="phone" name="phone" value="{{ user.phone }}" required class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
          </div>

          <div>
            <label for="address" class="block text-sm font-medium text-[#ec3183] mb-2">Street Address *</label>
            <input type="text" id="address" name="address" required placeholder="123 Main Street" class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="city" class="block text-sm font-medium text-[#ec3183] mb-2">City *</label>
              <input type="text" id="city" name="city" required class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
            </div>
            <div>
              <label for="state" class="block text-sm font-medium text-[#ec3183] mb-2">State/Province *</label>
              <input type="text" id="state" name="state" required class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="zip_code" class="block text-sm font-medium text-[#ec3183] mb-2">ZIP/Postal Code *</label>
              <input type="text" id="zip_code" name="zip_code" required class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
            </div>
            <div>
              <label for="country" class="block text-sm font-medium text-[#ec3183] mb-2">Country *</label>
              <input type="text" id="country" name="country" value="United States" required class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]">
            </div>
          </div>
        </form>
      </div>

      <!-- Payment Information (Placeholder) -->
      <div class="bg-white rounded-lg border border-pink-100 p-6 mb-6">
        <h2 class="text-2xl font-bold text-[#ec3183] mb-6">Payment Method</h2>
        <div class="space-y-4">
          <label class="flex items-center p-4 border-2 border-[#ec3183] rounded-lg cursor-pointer">
            <input type="radio" name="payment_method" value="card" checked class="w-4 h-4 text-[#ec3183]">
            <span class="ml-3 text-[#ec3183] font-medium">Credit/Debit Card</span>
          </label>
          <label class="flex items-center p-4 border-2 border-pink-200 rounded-lg cursor-pointer">
            <input type="radio" name="payment_method" value="paypal" class="w-4 h-4 text-[#ec3183]">
            <span class="ml-3 text-[#ec3183] font-medium">PayPal</span>
          </label>

          <!-- Card Payment Form -->
          <div id="card_form" class="mt-4 space-y-4">
            <p class="text-sm text-[#ec3183] opacity-70 italic">Payment integration coming soon. Use test card: 4242 4242 4242 4242</p>
            <div>
              <label for="card_number" class="block text-sm font-medium text-[#ec3183] mb-2">Card Number</label>
              <input type="text" id="card_number" placeholder="4242 4242 4242 4242" class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]" disabled>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="exp_date" class="block text-sm font-medium text-[#ec3183] mb-2">Expiry Date</label>
                <input type="text" id="exp_date" placeholder="MM/YY" class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]" disabled>
              </div>
              <div>
                <label for="cvv" class="block text-sm font-medium text-[#ec3183] mb-2">CVV</label>
                <input type="text" id="cvv" placeholder="123" class="w-full px-4 py-2 border border-pink-200 rounded-lg focus:outline-none focus:border-[#ec3183] text-[#ec3183]" disabled>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Order Summary Sidebar -->
    <div class="lg:col-span-1">
      <div class="bg-white rounded-lg border border-pink-100 p-6 sticky top-20">
        <h2 class="text-2xl font-bold text-[#ec3183] mb-6">Order Summary</h2>

        <!-- Items List -->
        <div class="space-y-3 mb-6 pb-6 border-b border-pink-100 max-h-96 overflow-y-auto">
          {% for item in items %}
            <div class="flex justify-between text-sm">
              <span class="text-[#ec3183]">{{ item.product.name }} x{{ item.quantity }}</span>
              <span class="font-semibold text-[#ec3183]">${{ item.get_total_price }}</span>
            </div>
          {% endfor %}
        </div>

        <!-- Summary -->
        <div class="space-y-4 mb-6 pb-6 border-b border-pink-100">
          <div class="flex justify-between text-[#ec3183]">
            <span>Subtotal</span>
            <span>${{ total_price }}</span>
          </div>
          <div class="flex justify-between text-[#ec3183]">
            <span>Shipping</span>
            <span class="text-green-600 font-semibold">Free</span>
          </div>
          <div class="flex justify-between text-[#ec3183]">
            <span>Tax (Estimated)</span>
            <span>$0.00</span>
          </div>
        </div>

        <!-- Total -->
        <div class="flex justify-between items-center mb-6 pb-6 border-b border-pink-100">
          <span class="text-xl font-bold text-[#ec3183]">Total</span>
          <span class="text-2xl font-bold text-[#ec3183]">${{ total_price }}</span>
        </div>

        <!-- Place Order Button -->
        <button type="submit" form="checkout_form" onclick="alert('Payment processing coming soon!')" class="w-full py-3 bg-gradient-to-r from-[#ec3183] to-[#31dec4] text-white font-semibold rounded-lg hover:shadow-lg transition-shadow">
          Place Order
        </button>

        <!-- Back to Cart -->
        <a href="{% url 'view-cart' %}" class="w-full mt-3 py-3 border-2 border-[#ec3183] text-[#ec3183] font-semibold rounded-lg hover:bg-pink-50 transition-colors text-center block">
          Back to Cart
        </a>
      </div>
    </div>
  </div>

  <form id="checkout_form" method="post" style="display: none;">
    {% csrf_token %}
  </form>
</div>

<!-- Messages -->
{% if messages %}
  <div class="fixed bottom-4 right-4 z-50 space-y-2 max-w-md">
    {% for message in messages %}
      <div class="flash-message {% if message.tags %}{{ message.tags }}{% endif %} bg-white rounded-lg shadow-lg p-4 border-l-4 {% if 'success' in message.tags %}border-green-500{% else %}border-red-500{% endif %}">
        <p class="text-sm font-medium">{{ message }}</p>
      </div>
    {% endfor %}
  </div>
{% endif %}
{% endblock %}
